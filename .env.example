# Chronos environment

# HTTP server
PORT=3000

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=chronos
POSTGRES_PASSWORD=chronos
POSTGRES_DB=chronos
POSTGRES_PORT=5432

# Effect / @effect/sql-pg connection string
DATABASE_URL=postgres://chronos:chronos@localhost:5432/chronos

# Better Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Comma-separated list of origins allowed to call the auth endpoints.
# Include the Vite dev server (5173) so the dashboard can sign in.
# On a same-origin Railway deploy, set this to your public URL.
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Effect cluster runner — defaults are correct for a single replica.
# Do NOT scale to multiple replicas without configuring cluster networking
# (the ticker is a cluster Singleton with one runner).
RUNNER_HOST=127.0.0.1
RUNNER_PORT=34430

# Optional: override where the backend reads the built SPA from.
# Defaults to web/dist relative to the source tree (set in the Dockerfile).
# STATIC_DIR=web/dist

# --- Railway notes ---------------------------------------------------------
# DATABASE_URL    -> reference the Postgres plugin: ${{ Postgres.DATABASE_URL }}
# BETTER_AUTH_URL -> https://<your-service>.up.railway.app  (backend serves the SPA too)
# TRUSTED_ORIGINS -> same value as BETTER_AUTH_URL
# PORT            -> injected by Railway automatically; leave unset there
